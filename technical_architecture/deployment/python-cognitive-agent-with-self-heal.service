[Unit]
Description=Cognitive Intelligence Agent with Self-Healing (Python Logic Layer)
Documentation=https://github.com/your-org/animal-vocalization
# Requires Rust field engine to be running first
Requires=rust-field-engine.service
After=rust-field-engine.service

[Service]
Type=simple
# Path to Python and the cognitive agent main script with self-healing
# Adjust this path to match your installation directory
ExecStart=/usr/bin/python3 /opt/cognitive/cognitive_agent_main.py
# Working directory for the cognitive agent
WorkingDirectory=/opt/cognitive
# Restart automatically on crash (Let it crash philosophy + Self-Healing)
Restart=always
# Wait 2 seconds before restart (gives Rust time to detect disconnect)
RestartSec=2
# Standard output to journal for logging
StandardOutput=journal
StandardError=journal
# Security hardening
NoNewPrivileges=true
PrivateTmp=true
# Environment variables
Environment="PYTHONUNBUFFERED=1"
Environment="RUST_HEARTBEAT_ENDPOINT=ipc:///tmp/cognitive_heartbeat.ipc"
Environment="CHECKPOINT_DIR=/opt/cognitive/state"
Environment="CHECKPOINT_INTERVAL_SEC=60"

[Install]
WantedBy=multi-user.target
